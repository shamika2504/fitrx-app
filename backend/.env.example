# ── Non-sensitive config (plain env var — also set on Cloud Run) ──────────────
GCP_PROJECT_ID=your-gcp-project-id

# ── Local development only ─────────────────────────────────────────────────────
# In production these are fetched from GCP Secret Manager automatically.

# PostgreSQL DSN for Cloud SQL pgvector (leave blank to disable locally)
CLOUD_SQL_DSN=

# OpenAI API key for pgvector embeddings (leave blank to disable locally)
OPENAI_API_KEY=
