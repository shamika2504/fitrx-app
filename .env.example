# ── Non-sensitive config (plain env var — also set on Cloud Run) ──────────────
# GCP project ID; needed to bootstrap Secret Manager and BigQuery clients.
GCP_PROJECT_ID=your-gcp-project-id

# ── Local development only ─────────────────────────────────────────────────────
# In production these are fetched automatically from GCP Secret Manager.
# Set them here only when running the backend locally (e.g. with `uvicorn`).

# PostgreSQL DSN for Cloud SQL pgvector instance.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
# Leave blank to disable semantic search locally (BigQuery fallback is used).
CLOUD_SQL_DSN=

# OpenAI API key for generating embeddings (text-embedding-3-small).
# Leave blank to disable embedding storage/retrieval locally.
OPENAI_API_KEY=
